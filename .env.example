# CARpsy — Variables de entorno
# Copia este archivo a .env y ajusta los valores a tu entorno.
# No se necesita ninguna API key. Todo corre 100% local.

# Ruta al binario llama-finetune-lora compilado de qvac-fabric-llm.cpp
# Si no lo defines, el script busca en ubicaciones comunes de Windows.
# FABRIC_PATH=C:/Users/User/Documents/qvac-fabric-llm.cpp/build/bin/Release/llama-finetune-lora.exe

# Ruta al modelo base GGUF (LLaMA 3.2 1B Instruct Q4_K_M)
# Si no lo defines, se busca automáticamente en models/*.gguf
# MODEL_PATH=C:/Users/User/Documents/CARpsy/models/llama-3.2-1b-instruct-q4_k_m.gguf

# Cómo compilar QVAC Fabric:
#   git clone https://github.com/tetherto/qvac-fabric-llm.cpp.git
#   cd qvac-fabric-llm.cpp && mkdir build && cd build
#   cmake .. -DLLAMA_CUDA=OFF    # CPU only
#   cmake .. -DLLAMA_CUDA=ON     # Con GPU NVIDIA
#   cmake --build . --config Release
