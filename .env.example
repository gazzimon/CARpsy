# CARpsy — Environment variables
# Copy this file to .env and adjust the values for your system.
# No API key required. Everything runs 100% locally.

# Full path to the compiled llama-finetune-lora binary from qvac-fabric-llm.cpp.
# If not set, the script searches common Windows build paths automatically.
# FABRIC_PATH=C:/Users/User/Documents/llama-b9672-bin/llama-finetune-lora.exe

# Full path to the base GGUF model.
# If not set, any *.gguf file found in models/ is used.
# MODEL_PATH=C:/Users/User/Documents/CARpsy/models/qwen3-1.7b-q4_k_m.gguf

# How to compile QVAC Fabric:
#   git clone https://github.com/tetherto/qvac-fabric-llm.cpp.git
#   cd qvac-fabric-llm.cpp && mkdir build && cd build
#   cmake .. -DLLAMA_CUDA=OFF    # CPU only
#   cmake .. -DLLAMA_CUDA=ON     # NVIDIA GPU
#   cmake --build . --config Release
