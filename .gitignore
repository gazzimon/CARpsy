env/

# Datasets (raw files are large)
data/raw/*.db
data/raw/*.sqlite
data/raw/*.csv
data/raw/*.json
!data/raw/.gitkeep

# Processed data
data/processed/*.jsonl
data/processed/*.parquet
!data/processed/.gitkeep

# Splits — incluidos en repo para reproducibilidad en Colab

# Models (too large for git, download separately)
models/*.gguf
!models/.gitkeep

# Output — los GGUF/optimizer son enormes, pero los reportes JSON son evidencia y se versionan
output/adapter/*
!output/adapter/.gitkeep
!output/adapter/*.json
output/checkpoints/*
!output/checkpoints/.gitkeep
!output/checkpoints/**/metadata.txt

